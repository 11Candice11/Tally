{
  "Jwt": {
    "Key": "",
    "Issuer": "InvoiceTrackerAPI",
    "Audience": "InvoiceTrackerUI"
  },
  "ConnectionStrings": {
    "Default": "",
    "Redis": ""
  },
  "Cors": {
    "AllowedOrigins": ""
  },
  "Email": {
    "Smtp": "smtp.gmail.com",
    "Port": "587",
    "Username": "",
    "Password": "",
    "From": "",
    "FromName": "TALLY "
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/tally-.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
